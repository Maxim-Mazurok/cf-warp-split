#!/usr/bin/env bash
#
# apply-override — daemon that maintains the SupplementalMatchDomains DNS override
#
# Runs as a LaunchDaemon. Applies a macOS dynamic-store entry that tells
# mDNSResponder to prefer our local dnsmasq over WARP's DNS proxy.
# Polls every 5 seconds and re-applies if the entry was cleared
# (e.g. after sleep/wake, WARP reconnect, network change).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/config"

SCUTIL=/usr/sbin/scutil
DNSMASQ_ADDRESS="127.0.0.1"
WARP_DNS_PROXY="127.0.2.2"
SERVICE_KEY="State:/Network/Service/CustomSplitDNS/DNS"
WARP_DAEMON_LABEL="com.cloudflare.1dot1dot1dot1.macos.warp.daemon"
OVERRIDE_POLL_INTERVAL_SECONDS=5
DNS_STACK_WAIT_INTERVAL_SECONDS=2

load_config_if_available() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi

    : "${WARP_DNS_HEALTHCHECK_DOMAIN:=}"
    : "${WARP_DNS_HEALTHCHECK_INTERVAL_SECONDS:=30}"
    : "${WARP_DNS_HEALTHCHECK_FAILURE_THRESHOLD:=3}"
    : "${WARP_DNS_HEALTHCHECK_RECOVERY_COOLDOWN_SECONDS:=$((5 * 60))}"
}

apply_override() {
    $SCUTIL <<EOF
d.init
d.add ServerAddresses * $DNSMASQ_ADDRESS
d.add SupplementalMatchDomains * ""
d.add SupplementalMatchOrders * 1
set $SERVICE_KEY
EOF
}

check_override() {
    $SCUTIL <<EOF | grep -q "$DNSMASQ_ADDRESS"
show $SERVICE_KEY
EOF
}

query_warp_dns_proxy() {
    /usr/bin/dig @"$WARP_DNS_PROXY" "$WARP_DNS_HEALTHCHECK_DOMAIN" A +short +time=2 +tries=1 2>/dev/null \
        | /usr/bin/grep -Eq '(^|[[:space:]])([0-9]{1,3}\.){3}[0-9]{1,3}$'
}

query_dnsmasq() {
    /usr/bin/dig @"$DNSMASQ_ADDRESS" example.com A +short +time=2 +tries=1 2>/dev/null \
        | /usr/bin/grep -Eq '(^|[[:space:]])([0-9]{1,3}\.){3}[0-9]{1,3}$'
}

query_split_dns_path() {
    if [[ -z "$WARP_DNS_HEALTHCHECK_DOMAIN" ]]; then
        return 0
    fi

    /usr/bin/dig @"$DNSMASQ_ADDRESS" "$WARP_DNS_HEALTHCHECK_DOMAIN" A +short +time=2 +tries=1 2>/dev/null \
        | /usr/bin/grep -Eq '(^|[[:space:]])([0-9]{1,3}\.){3}[0-9]{1,3}$'
}

dns_stack_ready() {
    query_dnsmasq && query_split_dns_path
}

wait_for_dns_stack() {
    until dns_stack_ready; do
        logger -t warp-split "Waiting for dnsmasq, retry proxy, and WARP DNS before applying override"
        sleep "$DNS_STACK_WAIT_INTERVAL_SECONDS"
    done
}

recover_warp_dns_proxy() {
    logger -t warp-split "Restarting WARP daemon after repeated DNS health check failures for $WARP_DNS_HEALTHCHECK_DOMAIN"

    if /bin/launchctl kickstart -k "system/$WARP_DAEMON_LABEL"; then
        logger -t warp-split "Restarted WARP daemon after DNS health check failures"
    else
        logger -t warp-split "Failed to restart WARP daemon after DNS health check failures"
    fi

    /usr/bin/dscacheutil -flushcache 2>/dev/null || true
    wait_for_dns_stack
    apply_override
}

run_warp_dns_healthcheck() {
    local current_time="$1"

    if [[ -z "$WARP_DNS_HEALTHCHECK_DOMAIN" ]]; then
        return
    fi

    if (( current_time - last_healthcheck_time < WARP_DNS_HEALTHCHECK_INTERVAL_SECONDS )); then
        return
    fi

    last_healthcheck_time="$current_time"

    if query_warp_dns_proxy; then
        healthcheck_failure_count=0
        return
    fi

    healthcheck_failure_count=$((healthcheck_failure_count + 1))
    logger -t warp-split "WARP DNS health check failed for $WARP_DNS_HEALTHCHECK_DOMAIN ($healthcheck_failure_count/$WARP_DNS_HEALTHCHECK_FAILURE_THRESHOLD)"

    if (( healthcheck_failure_count < WARP_DNS_HEALTHCHECK_FAILURE_THRESHOLD )); then
        return
    fi

    if (( current_time - last_recovery_time < WARP_DNS_HEALTHCHECK_RECOVERY_COOLDOWN_SECONDS )); then
        return
    fi

    last_recovery_time="$current_time"
    healthcheck_failure_count=0
    recover_warp_dns_proxy
}

load_config_if_available

healthcheck_failure_count=0
last_healthcheck_time=0
last_recovery_time=0

# Apply once the local forwarding path is ready on start
wait_for_dns_stack
apply_override
logger -t warp-split "Applied DNS override on start"

# Poll — re-apply if removed
while true; do
    sleep "$OVERRIDE_POLL_INTERVAL_SECONDS"

    if ! check_override; then
        wait_for_dns_stack
        apply_override
        logger -t warp-split "Re-applied DNS override after change detected"
    fi

    run_warp_dns_healthcheck "$(date +%s)"
done
