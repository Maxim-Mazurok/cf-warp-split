#!/usr/bin/env bash
#
# warp-split — manage split DNS for Cloudflare WARP on macOS
#
# Routes internal/corporate DNS through WARP's proxy while sending
# everything else to public DNS directly.
#
# Usage: ./warp-split <command>
# Commands: setup, teardown, enable, disable, status, generate, logs

set -euo pipefail

# ---------------------------------------------------------------------------
# Paths & constants
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/config"
CONFIG_EXAMPLE="$SCRIPT_DIR/config.example"
DAEMON_SCRIPT="$SCRIPT_DIR/apply-override"
RETRY_PROXY_SCRIPT="$SCRIPT_DIR/retry-proxy"

DAEMON_LABEL="com.local.split-dns"
DAEMON_PLIST="/Library/LaunchDaemons/$DAEMON_LABEL.plist"
RETRY_PROXY_LABEL="com.local.split-dns-retry-proxy"
RETRY_PROXY_PLIST="/Library/LaunchDaemons/$RETRY_PROXY_LABEL.plist"
SCUTIL_SERVICE_KEY="State:/Network/Service/CustomSplitDNS/DNS"
HOSTS_MARKER="# warp-split"

WARP_DNS_PROXY="127.0.2.2"
WARP_DNS_PROXY_ALT="127.0.2.3"
DNSMASQ_LISTEN="127.0.0.1"
RETRY_PROXY_LISTEN="127.0.0.1"
RETRY_PROXY_PORT="5354"

# Detect Homebrew prefix (Apple Silicon vs Intel)
if [[ -d /opt/homebrew ]]; then
    HOMEBREW_PREFIX="/opt/homebrew"
else
    HOMEBREW_PREFIX="/usr/local"
fi

DNSMASQ_CONFIG_DIR="$HOMEBREW_PREFIX/etc/dnsmasq.d"
DNSMASQ_LOG_FILE="$HOMEBREW_PREFIX/var/log/dnsmasq.log"

# ---------------------------------------------------------------------------
# Formatting
# ---------------------------------------------------------------------------

red()    { printf '\033[0;31m%s\033[0m' "$*"; }
green()  { printf '\033[0;32m%s\033[0m' "$*"; }
yellow() { printf '\033[0;33m%s\033[0m' "$*"; }
bold()   { printf '\033[1m%s\033[0m' "$*"; }

info()  { echo "  $(green "✔") $*"; }
warn()  { echo "  $(yellow "⚠") $*"; }
fail()  { echo "  $(red "✖") $*"; }
step()  { echo ""; echo "$(bold "▸ $*")"; }

# ---------------------------------------------------------------------------
# Config loading
# ---------------------------------------------------------------------------

load_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo ""
        fail "Config file not found: $CONFIG_FILE"
        echo "  Copy the example and edit it for your organization:"
        echo ""
        echo "    cp config.example config"
        echo "    \$EDITOR config"
        echo ""
        exit 1
    fi
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
}

load_config_if_present() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    fi
}

# ---------------------------------------------------------------------------
# Generators
# ---------------------------------------------------------------------------

generate_dnsmasq_config() {
    load_config

    local output_file="$DNSMASQ_CONFIG_DIR/split-dns.conf"

    cat > "$output_file" <<DNSMASQ_EOF
# Generated by warp-split — do not edit manually.
# Regenerate with: ./warp-split generate

# Listen on ${DNSMASQ_LISTEN}:53 (WARP uses ${WARP_DNS_PROXY}:53, no conflict)
listen-address=${DNSMASQ_LISTEN}
port=53
bind-interfaces

# Do NOT read /etc/resolv.conf (it points to WARP's proxy)
no-resolv
no-poll

# Local DNS cache
cache-size=1000

# Keep mDNSResponder's startup burst from making local clients time out.
strict-order
dns-forward-max=1000

# === Internal domains → SERVFAIL-retry proxy → WARP DNS proxies ===
# Retry proxy (${RETRY_PROXY_LISTEN}:${RETRY_PROXY_PORT}) forwards to
# ${WARP_DNS_PROXY} / ${WARP_DNS_PROXY_ALT} and retries on SERVFAIL,
# which WARP's DNS proxies return intermittently.
DNSMASQ_EOF

    for domain in "${INTERNAL_DOMAINS[@]}"; do
        echo "server=/${domain}/${RETRY_PROXY_LISTEN}#${RETRY_PROXY_PORT}" >> "$output_file"
    done

    echo "" >> "$output_file"
    echo "# Standard private TLDs → SERVFAIL-retry proxy → WARP DNS proxy" >> "$output_file"

    for tld in "${FALLBACK_TLDS[@]}"; do
        echo "server=/${tld}/${RETRY_PROXY_LISTEN}#${RETRY_PROXY_PORT}" >> "$output_file"
    done

    echo "" >> "$output_file"
    echo "# WARP internal connectivity check (direct, not via retry proxy)" >> "$output_file"
    echo "server=/warp-svc/${WARP_DNS_PROXY}" >> "$output_file"
    echo "server=/warp-svc/${WARP_DNS_PROXY_ALT}" >> "$output_file"

    echo "" >> "$output_file"
    echo "# Do not keep transient private-DNS negative answers around" >> "$output_file"
    echo "no-negcache" >> "$output_file"

    echo "" >> "$output_file"
    echo "# === External DNS (bypasses Cloudflare Gateway) ===" >> "$output_file"

    for server in "${PUBLIC_DNS_SERVERS[@]}"; do
        echo "server=${server}" >> "$output_file"
    done

    if [[ "${ENABLE_LOGGING:-false}" == "true" ]]; then
        echo "" >> "$output_file"
        echo "# Query logging (disable in config to turn off)" >> "$output_file"
        echo "log-async=100" >> "$output_file"
        echo "log-queries" >> "$output_file"
        echo "log-facility=${DNSMASQ_LOG_FILE}" >> "$output_file"
    fi

    info "Generated dnsmasq config: $output_file"
}

generate_launchdaemon_plist() {
    cat > "$DAEMON_PLIST" <<PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${DAEMON_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${DAEMON_SCRIPT}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/warp-split.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/warp-split.stderr.log</string>
</dict>
</plist>
PLIST_EOF

    info "Generated LaunchDaemon plist: $DAEMON_PLIST"
}

generate_retry_proxy_plist() {
    cat > "$RETRY_PROXY_PLIST" <<PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${RETRY_PROXY_LABEL}</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>python3</string>
        <string>${RETRY_PROXY_SCRIPT}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/warp-split-retry-proxy.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/warp-split-retry-proxy.stderr.log</string>
</dict>
</plist>
PLIST_EOF

    info "Generated retry-proxy LaunchDaemon plist: $RETRY_PROXY_PLIST"
}

wait_for_dnsmasq() {
    local attempt

    for attempt in {1..10}; do
        if /usr/bin/dig @"$DNSMASQ_LISTEN" example.com A +short +time=1 +tries=1 2>/dev/null | grep -Eq '(^|[[:space:]])([0-9]{1,3}\.){3}[0-9]{1,3}$'; then
            info "dnsmasq is answering DNS"
            return 0
        fi

        sleep 1
    done

    fail "dnsmasq did not answer a local DNS probe; refusing to apply DNS override"
    return 1
}

# ---------------------------------------------------------------------------
# /etc/hosts management
# ---------------------------------------------------------------------------

add_hosts_entry() {
    if grep -q "connectivity-check.warp-svc" /etc/hosts 2>/dev/null; then
        info "/etc/hosts entries already present"
        return
    fi

    chflags noschg,nouchg /etc/hosts 2>/dev/null || true
    echo "${WARP_DNS_PROXY} connectivity-check.warp-svc ${HOSTS_MARKER}" >> /etc/hosts
    echo "${WARP_DNS_PROXY_ALT} connectivity-check.warp-svc ${HOSTS_MARKER}" >> /etc/hosts
    chflags schg,uchg /etc/hosts 2>/dev/null || true

    info "Added connectivity-check.warp-svc to /etc/hosts"
}

remove_hosts_entry() {
    if ! grep -q "connectivity-check.warp-svc" /etc/hosts 2>/dev/null; then
        info "/etc/hosts entries already absent"
        return
    fi

    chflags noschg,nouchg /etc/hosts 2>/dev/null || true
    sed -i '' '/connectivity-check\.warp-svc/d' /etc/hosts
    chflags schg,uchg /etc/hosts 2>/dev/null || true

    info "Removed connectivity-check.warp-svc from /etc/hosts"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

command_setup() {
    step "Loading config"
    load_config
    info "Loaded ${#INTERNAL_DOMAINS[@]} internal domains, ${#PUBLIC_DNS_SERVERS[@]} public DNS servers"

    step "Installing dnsmasq"
    if command -v dnsmasq &>/dev/null; then
        info "dnsmasq already installed"
    else
        brew install dnsmasq
        info "dnsmasq installed"
    fi

    step "Generating dnsmasq config"
    mkdir -p "$DNSMASQ_CONFIG_DIR"
    generate_dnsmasq_config

    step "Generating LaunchDaemon"
    generate_launchdaemon_plist

    step "Generating retry-proxy LaunchDaemon"
    generate_retry_proxy_plist

    step "Adding /etc/hosts entry"
    add_hosts_entry

    step "Starting services"
    command_enable_quiet

    step "Done"
    info "Split DNS is active. Run $(bold "./warp-split status") to verify."
}

command_teardown() {
    step "Stopping services"
    command_disable_quiet

    step "Removing /etc/hosts entry"
    remove_hosts_entry

    step "Removing dnsmasq config"
    rm -f "$DNSMASQ_CONFIG_DIR/split-dns.conf"
    info "Removed dnsmasq config"

    step "Removing LaunchDaemon"
    rm -f "$DAEMON_PLIST"
    info "Removed LaunchDaemon plist"

    rm -f "$RETRY_PROXY_PLIST"
    info "Removed retry-proxy LaunchDaemon plist"

    step "Done"
    info "Split DNS fully removed. WARP controls all DNS again."
    echo "  dnsmasq was left installed — run $(bold "brew uninstall dnsmasq") to remove it."
}

command_enable_quiet() {
    launchctl load "$RETRY_PROXY_PLIST" 2>/dev/null || true
    info "Retry-proxy daemon loaded"

    brew services start dnsmasq 2>/dev/null || true
    info "dnsmasq started"

    wait_for_dnsmasq

    launchctl load "$DAEMON_PLIST" 2>/dev/null || true
    info "DNS override daemon loaded"

    dscacheutil -flushcache 2>/dev/null || true
    info "DNS cache flushed"
}

command_enable() {
    step "Enabling split DNS"
    command_enable_quiet
    step "Done"
}

command_disable_quiet() {
    # Remove scutil override
    /usr/sbin/scutil <<SCUTIL_EOF 2>/dev/null || true
remove $SCUTIL_SERVICE_KEY
SCUTIL_EOF
    info "DNS override removed"

    # Unload daemon
    launchctl unload "$DAEMON_PLIST" 2>/dev/null || true
    info "DNS override daemon unloaded"

    # Stop dnsmasq
    brew services stop dnsmasq 2>/dev/null || true
    info "dnsmasq stopped"

    # Stop retry proxy
    launchctl unload "$RETRY_PROXY_PLIST" 2>/dev/null || true
    info "Retry-proxy daemon unloaded"

    dscacheutil -flushcache 2>/dev/null || true
    info "DNS cache flushed"
}

command_disable() {
    step "Disabling split DNS"
    command_disable_quiet
    step "Done"
    info "All DNS goes through WARP again."
}

command_status() {
    load_config_if_present

    echo ""
    bold "  Split DNS Status"
    echo ""

    # dnsmasq
    if pgrep -x dnsmasq > /dev/null 2>&1; then
        info "dnsmasq: $(green "running") (pid $(pgrep -x dnsmasq))"
    else
        fail "dnsmasq: $(red "stopped")"
    fi

    # Retry proxy
    if launchctl print "system/$RETRY_PROXY_LABEL" &>/dev/null 2>&1; then
        info "Retry-proxy: $(green "running")"
    else
        fail "Retry-proxy: $(red "stopped")"
    fi

    # Override daemon
    if launchctl print "system/$DAEMON_LABEL" &>/dev/null 2>&1; then
        info "Override daemon: $(green "running")"
    else
        fail "Override daemon: $(red "stopped")"
    fi

    # Supplemental DNS
    if /usr/sbin/scutil <<< "show $SCUTIL_SERVICE_KEY" 2>&1 | grep -q "$DNSMASQ_LISTEN"; then
        info "DNS override: $(green "active")"
    else
        fail "DNS override: $(red "inactive")"
    fi

    # WARP DNS health
    local healthcheck_domain="${WARP_DNS_HEALTHCHECK_DOMAIN:-}"
    if [[ -n "$healthcheck_domain" ]]; then
        if /usr/bin/dig @"$WARP_DNS_PROXY" "$healthcheck_domain" A +short +time=2 +tries=1 2>/dev/null | grep -Eq '(^|[[:space:]])([0-9]{1,3}\.){3}[0-9]{1,3}$'; then
            info "WARP DNS health: $(green "ok") ($healthcheck_domain via $WARP_DNS_PROXY)"
        else
            fail "WARP DNS health: $(red "failing") ($healthcheck_domain via $WARP_DNS_PROXY)"
        fi
    fi

    # /etc/hosts
    if grep -q "connectivity-check.warp-svc" /etc/hosts 2>/dev/null; then
        info "/etc/hosts entry: $(green "present")"
    else
        fail "/etc/hosts entry: $(red "missing")"
    fi

    # WARP
    local warp_status
    warp_status="$(warp-cli status 2>&1 | head -1)"
    if echo "$warp_status" | grep -qi "connected"; then
        info "WARP: $(green "$warp_status")"
    else
        warn "WARP: $(yellow "$warp_status")"
    fi

    # Resolver order
    echo ""
    bold "  DNS Resolver Order"
    echo ""
    scutil --dns 2>&1 | awk '/^DNS configuration$/{found=1;next} /^DNS configuration \(for scoped/{exit} found && /^resolver #/{p=1} p{print}' | head -15 | sed 's/^/  /'
}

command_generate() {
    step "Regenerating dnsmasq config"
    generate_dnsmasq_config
    step "Restarting dnsmasq"
    brew services restart dnsmasq 2>/dev/null
    info "dnsmasq restarted with new config"
}

command_logs() {
    if [[ -f "$DNSMASQ_LOG_FILE" ]]; then
        tail -f "$DNSMASQ_LOG_FILE"
    else
        fail "Log file not found: $DNSMASQ_LOG_FILE"
        echo "  Enable logging in your config file and run $(bold "./warp-split generate")"
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<USAGE

$(bold "warp-split") — split DNS for Cloudflare WARP on macOS

$(bold "Usage:")  ./warp-split <command>

$(bold "Commands:")
  setup       Install dnsmasq, generate configs, start services
  teardown    Stop services, remove configs (keeps dnsmasq installed)
  enable      Start split DNS services
  disable     Stop split DNS services (WARP resumes full DNS control)
  status      Show current state of all components
  generate    Regenerate dnsmasq config from your config file
  logs        Tail the dnsmasq query log

$(bold "Quick start:")
  1. cp config.example config
  2. Edit config with your internal domains
  3. sudo ./warp-split setup

USAGE
}

# ---------------------------------------------------------------------------
# Entrypoint
# ---------------------------------------------------------------------------

# Commands that need root
needs_root() {
    if [[ $EUID -ne 0 ]]; then
        fail "This command must be run as root: $(bold "sudo ./warp-split $1")"
        exit 1
    fi
}

main() {
    local command="${1:-}"

    case "$command" in
        setup)    needs_root setup;    command_setup ;;
        teardown) needs_root teardown; command_teardown ;;
        enable)   needs_root enable;   command_enable ;;
        disable)  needs_root disable;  command_disable ;;
        generate) needs_root generate; command_generate ;;
        status)   command_status ;;
        logs)     command_logs ;;
        -h|--help|help|"")  usage ;;
        *)
            fail "Unknown command: $command"
            usage
            exit 1
            ;;
    esac
}

main "$@"
